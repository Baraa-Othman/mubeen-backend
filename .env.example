# Mubeen Backend — Environment Variables
# Copy this file to .env and fill in the values.

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Firebase credentials ──────────────────────────────────────────────────────
# LOCAL DEV: point to the key file on disk
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# RENDER / CLOUD DEPLOYMENT: paste the entire serviceAccountKey.json content
# as a single-line JSON string in this variable (leave blank for local dev).
# To get the value, run in terminal:  python -c "import json,sys; print(json.dumps(json.load(open('serviceAccountKey.json'))))"
FIREBASE_CREDENTIALS_JSON=
